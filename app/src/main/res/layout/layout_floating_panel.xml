<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="300dp"
    android:layout_height="400dp"
    android:background="@drawable/bg_floating_panel"
    android:orientation="vertical"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doc Search"
            android:textColor="#ebdbb2"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Close"
            android:tint="#fb4934" />

        <ImageView
            android:id="@+id/btnExitService"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_toStartOf="@id/btnClose"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:contentDescription="Exit"
            android:tint="#ebdbb2" />
    </RelativeLayout>

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/editbox_background_normal"
        android:hint="Search snippets..."
        android:padding="8dp"
        android:textColor="#ebdbb2"
        android:textColorHint="#928374"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

</LinearLayout>