<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BDoci" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.BDoci.MaterialAlertDialog</item>
    </style>

    <style name="ThemeOverlay.BDoci.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.BDoci.Dialog.Rounded</item>
    </style>

    <style name="ShapeAppearanceOverlay.BDoci.Dialog.Rounded" parent="">
        <item name="cornerSize">24dp</item>
    </style>
</resources>